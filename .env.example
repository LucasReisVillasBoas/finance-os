# Database
# ATENÇÃO: porta 5434 externamente (mapeada de 5432 no container)
DATABASE_URL=postgresql://financeos:financeos@localhost:5434/financeos?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
# OBRIGATÓRIO: gere um segredo aleatório com 32+ caracteres antes de rodar.
# Comando: openssl rand -hex 32
JWT_SECRET=GERE_UM_SEGREDO_AQUI_openssl_rand_-hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Evolution API (WhatsApp) — OPCIONAL
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=your-evolution-api-key-here

# BRAPI (cotações de ações B3) — OPCIONAL
# brapi.dev oferece um token gratuito que libera os endpoints de cotação.
# Sem o token a busca de ações funciona em modo best-effort (pode vir sem preço).
# Cotações de moedas (USD/EUR) usam a AwesomeAPI e NÃO precisam de chave.
BRAPI_TOKEN=

# App
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=debug

# CORS — em produção, substitua pelo(s) domínio(s) real(is) do frontend.
# Múltiplos domínios separados por vírgula.
# Exemplo produção: CORS_ORIGINS=https://app.financeos.com.br
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Backup
# Diretório para salvar os backups (padrão: ./backups)
# BACKUP_DIR=/var/backups/financeos
# Dias de retenção dos backups (padrão: 7)
# BACKUP_RETAIN_DAYS=7
