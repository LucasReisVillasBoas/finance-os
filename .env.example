# Database
DATABASE_URL=postgresql://financeos:financeos@localhost:5432/financeos

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-random-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=your-evolution-api-key-here

# BRAPI (cotações de ações B3) — OPCIONAL
# brapi.dev oferece um token gratuito que libera os endpoints de cotação.
# Sem o token a busca de ações funciona em modo best-effort (pode vir sem preço).
# Cotações de moedas (USD/EUR) usam a AwesomeAPI e NÃO precisam de chave.
BRAPI_TOKEN=

# App
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
